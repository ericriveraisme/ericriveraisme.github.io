{
  "name": "ericriveraisme-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Eric Rivera's FF6-inspired portfolio app",
  "main": "FF6PortfolioApp.jsx",
  "scripts": {
    "start": "webpack serve --mode development",
    "start:cms": "webpack serve --mode development --port 3003",
    "build": "cross-env NODE_ENV=production webpack --mode production",
    "validate:content": "node scripts/validate-lab-articles.mjs",
    "check:admin-prod": "node scripts/check-admin-production-readiness.mjs",
    "admin:config:local": "node scripts/switch-admin-config.mjs local",
    "admin:config:prod": "node scripts/switch-admin-config.mjs prod",
    "cms:proxy": "cross-env PORT=8082 decap-server",
    "cms:dev": "npm run cms:proxy",
    "cms:local": "concurrently \"npm run cms:proxy\" \"npm run start:cms\"",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.18.6",
    "autoprefixer": "^10.4.24",
    "babel-loader": "^9.1.3",
    "cross-env": "^10.1.0",
    "concurrently": "^9.2.1",
    "decap-server": "^3.2.0",
    "css-loader": "^6.8.1",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.19",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
